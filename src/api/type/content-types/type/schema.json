{
  "kind": "collectionType",
  "collectionName": "types",
  "info": {
    "singularName": "type",
    "pluralName": "types",
    "displayName": "Type"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "minLength": 3,
      "required": true,
      "unique": true
    },
    "contents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::content.content",
      "mappedBy": "type"
    },
    "missions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::mission.mission",
      "mappedBy": "type"
    }
  }
}
