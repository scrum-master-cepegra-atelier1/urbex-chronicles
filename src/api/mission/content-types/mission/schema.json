{
  "kind": "collectionType",
  "collectionName": "missions",
  "info": {
    "singularName": "mission",
    "pluralName": "missions",
    "displayName": "Mission"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "minLength": 5,
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "latitude": {
      "type": "decimal"
    },
    "longitude": {
      "type": "decimal"
    },
    "threshold": {
      "type": "integer"
    },
    "media": {
      "type": "component",
      "component": "media.media",
      "repeatable": false
    },
    "achievement": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::achievement.achievement"
    },
    "hint": {
      "type": "text"
    }
  }
}
