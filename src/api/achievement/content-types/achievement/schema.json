{
  "kind": "collectionType",
  "collectionName": "achievements",
  "info": {
    "singularName": "achievement",
    "pluralName": "achievements",
    "displayName": "Achievement"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "minLength": 3,
      "required": true,
      "unique": true
    },
    "experience": {
      "type": "biginteger",
      "required": true
    },
    "users": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "achievements"
    },
    "mission": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::mission.mission",
      "inversedBy": "achievements"
    }
  }
}
